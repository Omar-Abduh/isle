# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=habittracker
POSTGRES_USER=ht_user
POSTGRES_PASSWORD=change_me_strong_password_min32chars

# ─── Spring Boot ──────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/habittracker
SPRING_DATASOURCE_USERNAME=ht_user
SPRING_DATASOURCE_PASSWORD=change_me_strong_password_min32chars

# JWT keys are mounted as Docker secrets (see secrets/ dir)
# These paths point to the mounted secret files inside the container
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# Google OAuth — Client Secret is BACKEND ONLY, never in frontend
GOOGLE_CLIENT_ID=<from_google_cloud_console>
GOOGLE_CLIENT_SECRET=<from_google_cloud_console>

# ─── Tauri / Frontend (Vite build-time variables) ────────────────────────────
# These are baked into the desktop app at build time — do NOT include secrets
VITE_API_BASE_URL=https://your-vps-domain
VITE_GOOGLE_CLIENT_ID=<same_client_id_as_above>
VITE_REDIRECT_URI=https://your-vps-domain/success.html
VITE_DEEP_LINK_SCHEME=habittracker
COMPOSE_PROJECT_NAME=isle